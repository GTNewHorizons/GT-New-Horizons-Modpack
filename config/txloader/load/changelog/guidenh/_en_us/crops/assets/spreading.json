        "rotY": 50.0
      },
      "layer": null,
      "annotations": [
        {
          "type": "text",
          "text": "The stats of the spread crop will likely change, and you can use a Plant Lens to find them out!",
          "independent": true,
          "yOffset": -80,
          "maxWidth": 180,
          "color": "0xFFCCCCFF"
        },
        {
          "type": "text",
          "text": "If not fertilized, the stats will all change in the range of -2 -> +4. This is +0 -> +4 if fertilized",
          "independent": true,
          "xOffset": -20,
          "yOffset": 60,
          "maxWidth": 180,
          "color": "0xFF00FFFF"
        },
        {
         "type": "input",
          "x": 0, "y": 1, "z": 1,
          "inputType": "rmb",
          "item": "cropsnh:fertilizer"
        }
      ]
    },
    {
      "time": 360,
      "label": "Weeds",
      "camera": {
        "rotY": -110.0
      },
      "layer": null,
      "blockChanges": [
        {
          "x": 0, "y": 0, "z": -1, "block": "minecraft:grass", "particles": true
        },
        {

          "x": 0, "y": 1, "z": -1, "block": "cropsnh:cropSticks", "particles": false,
          "nbt": "{progress:0,fert:0,water:0,weedEX:0,crop:{amount:1,crop:cropsnh:weed,ga:1,gr:1,re:1,scan:1}}"
        }
      ],
      "annotations": [
        {
          "type": "text",
          "text": "Weeds will always randomly pop up on cropsticks (and doubles!) unless they have **Weed-Ex**",
          "independent": true,
          "xOffset": -20,
          "yOffset": 60,
          "maxWidth": 180,
          "color": "0xFFFF0088"
        },
        {
          "type": "box",
          "minX": 0.05, "minY": 1.05, "minZ": -0.05,
          "maxX": 0.95, "maxY": 1.95, "maxZ": -0.95,
          "color": "ox88FF0088",
          "lineWidth": 1.5,
          "alwaysOnTop": false
        }
      ]
    },
    {
      "time": 480,
      "label": "Sickness",
      "camera": {
        "rotY": -130.0

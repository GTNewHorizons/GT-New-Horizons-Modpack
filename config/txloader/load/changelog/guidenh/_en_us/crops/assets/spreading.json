          "yOffset": -80,
          "maxWidth": 180,
          "color": "0xFFCCCCFF"
        }
      ]
    },
    {
      "time": 120,
      "label": "First Spread",
      "camera": {
        "rotY": 70.0
      },
      "layer": null,
      "blockChanges": [
        {
        "x": 0, "y": 1, "z": 1, "block": "cropsnh:cropSticks", "particles": false,
          "nbt": "{progress:0,fert:0,water:0,weedEX:0,crop:{amount:1,crop:cropsnh:bonsaiOak,ga:1,gr:1,re:1,scan:1}}"
        }
      ],
      "annotations": [
        {
          "type": "text",
          "text": "If the plant is able to grow on the adjacent crop sticks, they will attempt to spread to that crop stick",
          "independent": true,
          "yOffset": -80,
          "maxWidth": 180,
          "color": "0xFFCCCCFF"
        }
      ]
    },
